# CODEOWNERS — Qlik Agent Registry
#
# This file defines who must review and approve pull requests for each
# path in the repository. GitHub enforces these rules automatically when
# branch protection is configured with "Require review from Code Owners".
#
# Syntax: <path pattern>    <@owner or @org/team> [additional owners...]
#
# Rules are evaluated top-to-bottom. The LAST matching rule wins.
# https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners


# -----------------------------------------------------------------------
# Default: catch-all for anything not explicitly listed below
# -----------------------------------------------------------------------
*                                   @qlik-oss/ai-official-maintainers


# -----------------------------------------------------------------------
# official/ — Qlik-owned artifacts
# Only core maintainers can approve changes here
# -----------------------------------------------------------------------
/official/                          @qlik-oss/ai-official-maintainers


# -----------------------------------------------------------------------
# community/ — External contributions
# Either core maintainers OR community maintainers can approve
# -----------------------------------------------------------------------
/community/                         @qlik-oss/ai-official-maintainers @qlik-oss/ai-community-maintainers


# -----------------------------------------------------------------------
# schemas/ — Versioned schema definitions
# Schema changes are high-impact; core maintainers only
# -----------------------------------------------------------------------
/schemas/                           @qlik-oss/ai-official-maintainers


# -----------------------------------------------------------------------
# registry/ — Auto-generated catalog
# Should never be edited manually; core maintainers own it regardless
# -----------------------------------------------------------------------
/registry/                          @qlik-oss/ai-official-maintainers


# -----------------------------------------------------------------------
# tools/ — CLI, validator, scaffold scripts
# Core maintainers own the toolchain
# -----------------------------------------------------------------------
/tools/                             @qlik-oss/ai-official-maintainers


# -----------------------------------------------------------------------
# docs/ — Contribution guide, authoring spec, governance docs
# Core maintainers own policy documents; community maintainers can
# propose changes but core maintainers must approve
# -----------------------------------------------------------------------
/docs/                              @qlik-oss/ai-official-maintainers


# -----------------------------------------------------------------------
# .github/ — CI workflows, PR templates, and this file itself
# Tightly controlled: any change here affects the entire governance model
# -----------------------------------------------------------------------
/.github/                           @qlik-oss/ai-official-maintainers


# -----------------------------------------------------------------------
# Root-level governance files
# -----------------------------------------------------------------------
/LICENSE                            @qlik-oss/ai-official-maintainers
/CONTRIBUTING.md                    @qlik-oss/ai-official-maintainers
/SECURITY.md                        @qlik-oss/ai-official-maintainers
/README.md                          @qlik-oss/ai-official-maintainers
